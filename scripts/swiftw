#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
resolve_shared_cache_root() {
  local common_git_dir

  if common_git_dir="$(git -C "$ROOT_DIR" rev-parse --git-common-dir 2>/dev/null)"; then
    if [[ "$common_git_dir" != /* ]]; then
      common_git_dir="$ROOT_DIR/$common_git_dir"
    fi

    if [[ -d "$common_git_dir" ]]; then
      cd "$(dirname "$common_git_dir")" && pwd
      return
    fi
  fi

  printf '%s\n' "$ROOT_DIR"
}

SHARED_CACHE_ROOT="${HANDAGENT_SHARED_CACHE_ROOT:-$(resolve_shared_cache_root)}"
CACHE_DIR="${HANDAGENT_SWIFT_MODULE_CACHE_DIR:-${HANDAGENT_SWIFT_CACHE_DIR:-$ROOT_DIR/.cache/swift}}"
SWIFTPM_CACHE_DIR="${HANDAGENT_SWIFTPM_CACHE_DIR:-$SHARED_CACHE_ROOT/.cache/swiftpm}"
CLANG_CACHE_DIR="$CACHE_DIR/clang-module-cache"
SWIFT_CACHE_DIR="$CACHE_DIR/swift-module-cache"
WORKSPACE_DEPENDENCIES_READY=0

mkdir -p "$CLANG_CACHE_DIR" "$SWIFT_CACHE_DIR" "$SWIFTPM_CACHE_DIR"

export CLANG_MODULE_CACHE_PATH="$CLANG_CACHE_DIR"
export SWIFT_MODULECACHE_PATH="$SWIFT_CACHE_DIR"

swift_with_cache() {
  case "${1:-}" in
    build|test|run|package)
      swift "$1" --cache-path "$SWIFTPM_CACHE_DIR" "${@:2}"
      ;;
    *)
      swift "$@"
      ;;
  esac
}

ensure_workspace_dependencies() {
  if [[ "$WORKSPACE_DEPENDENCIES_READY" == "1" ]]; then
    return
  fi

  if [[ -d "$ROOT_DIR/node_modules" ]]; then
    WORKSPACE_DEPENDENCIES_READY=1
    return
  fi

  echo "[swiftw] node_modules missing, running pnpm install..." >&2
  (
    cd "$ROOT_DIR"
    pnpm install
  )
  WORKSPACE_DEPENDENCIES_READY=1
}

ensure_thread_window_web_build() {
  if [[ -n "${HANDAGENT_THREAD_WINDOW_WEB_URL:-}" ]]; then
    return
  fi

  ensure_workspace_dependencies
  (
    cd "$ROOT_DIR"
    pnpm --filter handagent-thread-window-web build
  )
}

ensure_electron_shell_build() {
  ensure_workspace_dependencies
  (
    cd "$ROOT_DIR"
    pnpm --filter handagent-electron-shell build
  )
}

if [[ "${1:-}" == "test" || "${1:-}" == "build" ]]; then

  tmp_log="$(mktemp -t "swiftw-${1:-swift}.XXXXXX")"
  trap 'rm -f "$tmp_log"' EXIT

  if swift_with_cache "$@" >"$tmp_log" 2>&1; then
    if [[ "${1:-}" == "build" ]]; then
      echo "success"
    else
      echo "SUCCESS"
    fi
    exit 0
  else
    status=$?
    cat "$tmp_log"
    exit "$status"
  fi
fi

if [[ "${1:-}" == "run" && "${2:-}" == "HandAgentDesktop" ]]; then
  ensure_thread_window_web_build
  ensure_electron_shell_build
fi

swift_with_cache "$@"
